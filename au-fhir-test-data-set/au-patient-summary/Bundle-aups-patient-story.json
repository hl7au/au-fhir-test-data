        "text" : {
          "status" : "generated",
          "div" : "<div xmlns=\"http://www.w3.org/1999/xhtml\" xml:lang=\"en-AU\" lang=\"en-AU\">\n                <p>Health problems as reported by the patient:</p>\n                  <ul>\n                    <li>My prostate cancer has come back and spread to my bones</li>\n                    <li>Trouble with my digestion</li>\n                    <li>Problems with my skin</li>\n                    <li>Infections are hard to fight off</li>\n                    <li>Not as sharp mentally as I used to be</li>\n                    <li>Bad pain in my back and stomach</li>\n                  </ul>\n              </div>"
        },
